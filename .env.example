# VetCare environment overrides — placeholders only, no real secrets.
#
# Variable names follow the ASP.NET Core configuration convention
# (double-underscore separators map to JSON nesting). Applied on top of
# appsettings.json / appsettings.Development.json.
#
# Local quickstart (devcontainer + docker compose) does NOT need this file:
# the values in appsettings.Development.json already match the services in
# docker-compose.yml. Use this file when overriding for production-like
# deployments or alternate hosts.
#
# To load into a shell session:
#   set -a; source .env; set +a

# ---- ASP.NET Core ---------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# ---- PostgreSQL -----------------------------------------------------------
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=vetcare;Username=vetcare;Password=CHANGE_ME

# ---- JWT bearer -----------------------------------------------------------
# Secret MUST be at least 32 bytes for HS256.
Jwt__Secret=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES_LONG
Jwt__Issuer=vetcare-api
Jwt__Audience=vetcare-clients
Jwt__ExpiryMinutes=60

# ---- AWS (real S3 + SQS in prod; LocalStack in dev) -----------------------
# Leave Aws__ServiceUrl blank when using real AWS.
Aws__Region=us-east-1
Aws__ServiceUrl=http://localhost:4566
Aws__AccessKey=test
Aws__SecretKey=test

# ---- S3 (pet photo storage) ----------------------------------------------
S3__BucketName=vetcare-pets
S3__ServiceUrl=http://localhost:4566

# ---- MongoDB (audit log) -------------------------------------------------
Mongo__ConnectionString=mongodb://localhost:27017
Mongo__DatabaseName=vetcare
Mongo__AuditCollectionName=audit_log
